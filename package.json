{
  "name": "design-system-mobile",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "syncpack:list": "yarn syncpack list-mismatches",
    "syncpack:fix": "yarn syncpack fix-mismatches",
    "syncpack:update": "yarn syncpack update",
    "syncpack:format": "yarn syncpack format",
    "docs:build": "mkdocs serve -a localhost:8080",
    "docker:build": "docker build -t equinor/oss-web .",
    "docker:start": "docker run -p 8080:8080 equinor/oss-web",
    "docker:inspect": "docker run -it equinor/oss-web /bin/sh",
    "lint:component": "turbo run lint --filter @equinor/design-system-mobile-components",
    "lint:all": "turbo run lint"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.32.0",
    "prettier": "^3.5.3",
    "syncpack": "^13.0.3",
    "tsup": "^8.5.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
