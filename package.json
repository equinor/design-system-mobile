{
  "name": "design-system-mobile",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clean:all": "turbo run clean && rm -rf node_modules .turbo .pnpm",
    "clean:storybook": "pnpm --filter @equinor/mobile-storybook clean",
    "syncpack:list": "pnpm syncpack list-mismatches",
    "syncpack:fix": "pnpm syncpack fix-mismatches",
    "syncpack:update": "pnpm syncpack update",
    "syncpack:format": "pnpm syncpack format",
    "docs:build": "mkdocs serve -a localhost:8080",
    "docker:build": "docker build -t equinor/oss-web .",
    "docker:start": "docker run -p 8080:8080 equinor/oss-web",
    "docker:inspect": "docker run -it equinor/oss-web /bin/sh",
    "lint:component": "turbo run lint --filter @equinor/eds-mobile-components",
    "lint:all": "turbo run lint",
    "dev:storybook": "turbo run dev --filter @equinor/mobile-storybook",
    "clear:storybook": "pnpm --filter @equinor/mobile-storybook exec rm -rf .expo node_modules/.cache"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^9.25.0",
    "prettier": "^3.5.3",
    "syncpack": "^13.0.3",
    "tsup": "^8.5.0",
    "turbo": "^2.5.4",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/**/*"
  ]
}