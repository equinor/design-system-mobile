{
  "name": "@equinor/design-system-mobile-components",
  "description": "A React Native component library implementing the Equinor Design System.",
  "version": "0.1.0",
  "author": {
    "name": "Equinor Design System Mobile"
  },
  "bugs": "https://github.com/equinor/design-system-mobile/issues",
  "dependencies": {
    "@floating-ui/react-native": "^0.10.1",
    "react-error-boundary": "^4.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react": "^14.0.0",
    "@testing-library/react-native": "^12.3.0",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^9.32.0",
    "jest-expo": "~52.0.1",
    "react-native-reanimated": "~3.16.1",
    "react-test-renderer": "18.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0"
  },
  "//": [
    "@equinor/eslint-config-mad : re-setup dependencies so they don't rely on the mad monorepo",
    "@equinor/mad-tsconfig : re-setup dependencies so they don't rely on the mad monorepo"
  ],
  "files": [
    "CODE_OF_CONDUCT.md",
    "LICENSE",
    "CHANGELOG.md",
    "dist"
